public func sort<$T$>(ArrayLike<$T$> array, Compare<$T$> cmp) {
	sort(array, cmp, 0, array.getLength() - 1);
} 

public class Compare<$T$> {
	public varfunc compare(a : T, b : T) : int;
}
public class IntSmaller : Compare<$int$> {
	public varfunc compare(a : int, b : int) : int {
		if (a == b) return 0;
		else if (a > b) return -1;
		else return 1;
	}
}
public class UIntSmaller : Compare<$uint$> {
    public varfunc compare(a : uint, b : uint) : uint {
		if (a == b) return 0;
		else if (a > b) return -1;
		else return 1;
	}
}
public class LongSmaller : Compare<$long$> {
    public varfunc compare(a : long, b : long) : long {
        if (a == b) return 0;
        else if (a > b) return -1;
        else return 1;
    }
}



