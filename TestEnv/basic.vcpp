public class ArrayLike<$T$> {
	public varfunc get(index : int) : T;
	public varfunc set(index : int, data : ValueT) : T;
	public varfunc getLength() : uint;
	public void swap(x : int, y : int) : void;
}
public class MapLike<$KeyT, ValueT$> {
	public varfunc get(index : keyT) : T;
	public varfunc set(index : keyT, data : ValueT) : T;
}

public class String : ArrayLike<$char$> {
	public varfunc get(index : int) : char;
	public varfunc set(index : int, dt : char) : void;
	public func getLength() : uint;
	public func resize(length : int);
	public func append(dt : char)
	public constructer();
	public constructer(source : String);
	public func __init__(source : char[]);
	
	private var data : char[];
	private var length : uint, capacity : uint;
}

public class Array<$T$> : ArrayLike<$T$> {
	public constructer() { }
	public constructer(int length, T initData) {
		while (length--) append(initData);
	}
    public varfunc get(index : int) : T {
		return data[index];
	}
	public varfunc set(index : int, dt : T) : {
		data[index] = dt;
	}
    public varfunc getLength() : uint {
		return length;
	}
	public varfunc swap(x : int, y : int) : void {
		T tmp = data[x];
		data[x] = data[y];
		data[y] = tmp;
	}

	public func append(dt : T) : void {
		if (length == capacity) {
			var newCapacity = capacity;
			if (capacity == 0) newCapacity = 1;
			else newCapacity <<= 1;
			var newData = new T[newCapacity];
			for (var i = 0; i < capacity; i++) newData[i] = data[i];
			data = newData;
		}
		data[length++] = dt;
	}

    private var data : T[];
	private var length : uint, capacity : uint;
}

